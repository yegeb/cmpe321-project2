<!DOCTYPE html>
<html>
<head><title>Register Referee - TransferDB</title></head>
<body>
<%- include('partials/flash') %>
<h1>Register as Referee</h1>
<form method="POST" action="/register/referee">
  <p><label>Username: <input type="text" name="username" required></label></p>
  <p><label>Password: <input type="password" name="password" required></label></p>
  <p><label>Name: <input type="text" name="name" required></label></p>
  <p><label>Surname: <input type="text" name="surname" required></label></p>
  <p><label>Nationality: <input type="text" name="nationality" required></label></p>
  <p><label>Date of Birth (YYYY-MM-DD): <input type="date" name="date_of_birth" required></label></p>
  <p><label>License Level (e.g. FIFA, UEFA Elite): <input type="text" name="license_level" required></label></p>
  <p><label>Years of Experience: <input type="number" name="years_experience" min="0" required></label></p>
  <p><button type="submit">Register</button></p>
</form>
<p><a href="/register">Back</a> | <a href="/login">Login</a></p>
</body>
</html>
